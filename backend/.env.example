# Application
APP_ENV=development
APP_NAME=ecomAgentOS
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=6200

# Secret key (required – never leave as default in production)
SECRET_KEY=change-me-in-production

# Database (asyncpg dialect)
DATABASE_URL=postgresql+asyncpg://ecom:change-me@localhost:5432/ecomagentos

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM provider selection: agnes | openai | deepseek | mock
LLM_PROVIDER=agnes

# Agnes
AGNES_API_KEY=your-agnes-key-here
AGNES_BASE_URL=https://api.agnes.ai/v1
AGNES_DEFAULT_MODEL=agnes-large-latest

# OpenAI
OPENAI_API_KEY=your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
